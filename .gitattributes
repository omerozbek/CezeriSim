# Force LF endings on files that are copied into or mounted in the Linux SITL
# container. With Git for Windows' default core.autocrlf=true these would be
# checked out as CRLF, and the container then fails at startup with:
#   exec /home/ardupilot/entrypoint.sh: no such file or directory
*.sh       text eol=lf
*.py       text eol=lf
*.parm     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
Dockerfile text eol=lf

# Large packaged binaries stored in Git LFS
*.ucas filter=lfs diff=lfs merge=lfs -text
*.exe filter=lfs diff=lfs merge=lfs -text
*.pak filter=lfs diff=lfs merge=lfs -text
*.utoc filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text

# Linux / macOS builds: the main game binaries are extensionless (ELF / Mach-O),
# so match shared libraries by extension and the binaries by directory.
# GitHub rejects non-LFS files over 100 MB — these rules MUST be in place
# before the first Linux/Mac build is committed.
*.so    filter=lfs diff=lfs merge=lfs -text
*.dylib filter=lfs diff=lfs merge=lfs -text
Linux/**/Binaries/** filter=lfs diff=lfs merge=lfs -text
Mac/**/Binaries/**   filter=lfs diff=lfs merge=lfs -text
Mac/**/MacOS/**      filter=lfs diff=lfs merge=lfs -text

# Exception: any shell script inside those trees must stay plain text with LF
# endings (the directory rules above would otherwise store it as an opaque blob).
Linux/**/Binaries/**/*.sh -filter -diff -merge text eol=lf
Mac/**/*.sh              -filter -diff -merge text eol=lf
