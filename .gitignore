# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Unreal Engine runtime output (regenerated every run) — any platform tree
**/CezeriSim/Saved/

# Per-machine runtime settings written by the game's Settings menu
# (camera / connection / gps / graphics / wind / world *.json). These hold
# local, machine-specific state (e.g. absolute image paths, map origin/layout)
# and are rewritten on save; a fresh clone falls back to built-in defaults.
# Any platform tree (Windows / Mac / Linux).
**/CezeriSim/Config/

# Debug symbols (Windows / Linux / macOS)
*.pdb
*.debug
*.sym
*.dSYM/

# Generated by start_sitl_docker.py from the active vehicle's params.parm
**/CezeriSim/Scripts/vehicle.parm

# Fleet files written by start_sitl_docker.py at launch (per-UAV params +
# docker-compose.fleet.yml); regenerated from the active vehicle each run.
**/CezeriSim/Scripts/generated/

# MAVLink telemetry logs and script logs
*.tlog
*.tlog.raw
**/CezeriSim/Scripts/control/logs/

# SITL runtime files
eeprom.bin

# OS cruft
Thumbs.db
desktop.ini
.DS_Store

# Editor/IDE
.vscode/
.idea/
